# frozen_string_literal: true

class <%= class_name %>Serializer < ActiveModel::Serializer
  attributes :id, <%= attributes.reject { |attr| attr.type == :references }.map { |attr| ":#{attr.name}" }.join(", ") %>
<% belongs_to_attributes.each do |attr| -%>
  belongs_to :<%= attr.name %>
<% end -%>
end
